# Database Configuration
# คัดลอกไฟล์นี้เป็น .env และแก้ไขตามสภาพแวดล้อมของคุณ

# For XAMPP (Default)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ichoice_
DB_USER=root
DB_PASS=

# For MAMP (Uncomment to use)
# DB_HOST=127.0.0.1
# DB_PORT=8889
# DB_NAME=ichoice_
# DB_USER=root
# DB_PASS=

# Application Environment
# development = แสดง error message แบบละเอียด
# production = แสดง error message แบบปลอดภัย
APP_ENV=development
